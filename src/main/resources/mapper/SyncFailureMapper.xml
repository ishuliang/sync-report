<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.helianhealth.family.he.admin.db.mapper.SyncFailureMapper">

    <resultMap id="failureMap" type="SyncFailure">
        <id property="id" column="id"/>
        <result property="taskIdRef" column="task_id_ref"/>
        <result property="hospitalFid" column="hospital_fid"/>
        <result property="month" column="month"/>
        <result property="customerName" column="customer_name"/>
        <result property="customerIdno" column="customer_idno"/>
        <result property="stage" column="stage"/>
        <result property="payload" column="payload"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="retryTimes" column="retry_times"/>
        <result property="resolved" column="resolved"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sync_failure(task_id_ref, hospital_fid, month, customer_name, customer_idno,
                                 stage, payload, error_msg, retry_times, resolved)
        VALUES(#{taskIdRef}, #{hospitalFid}, #{month}, #{customerName}, #{customerIdno},
               #{stage}, #{payload}, #{errorMsg}, #{retryTimes}, #{resolved})
    </insert>

    <select id="selectUnresolved" resultMap="failureMap">
        SELECT * FROM sync_failure WHERE resolved = 0 ORDER BY id
    </select>

    <update id="markResolved">
        UPDATE sync_failure SET resolved = 1 WHERE id = #{id}
    </update>

    <update id="incrementRetry">
        UPDATE sync_failure SET retry_times = retry_times + 1 WHERE id = #{id}
    </update>

</mapper>
